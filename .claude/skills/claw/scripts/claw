#!/usr/bin/env python3
"""
claw — NanoClaw CLI (v2)

Send a prompt to your NanoClaw agent via the local CLI socket.

Usage:
  claw "What is 2+2?"
  echo "prompt text" | claw --pipe
  cat prompt.txt | claw --pipe "Summarize this report"
  claw --list-groups

The running NanoClaw service exposes a Unix socket at `data/cli.sock`.
claw connects, writes the prompt as a single JSON line, then reads JSON
replies until the stream goes quiet, then exits.

Preconditions:
  - NanoClaw v2 service running (launchctl/systemd).
  - An agent group wired to the `cli/local` messaging group
    (see `/init-cli-agent` or `/manage-channels`).
"""

from __future__ import annotations

import argparse
import json
import os
import socket
import sqlite3
import sys
import time
from pathlib import Path

# ── Globals ─────────────────────────────────────────────────────────────────

VERBOSE = False
SILENCE_SECS = 2.0       # exit after this much quiet time following the first reply
DEFAULT_TIMEOUT = 300    # hard wait for the first reply


def dbg(*args):
    if VERBOSE:
        print("»", *args, file=sys.stderr)


# ── Config ──────────────────────────────────────────────────────────────────

def _find_nanoclaw_dir() -> Path:
    """Locate the NanoClaw installation directory.

    Resolution order:
    1. NANOCLAW_DIR env var
    2. Walk up from this script — v2 marker is `data/cli.sock` or `data/v2.db`
    3. ~/src/nanoclaw (legacy default)
    """
    if env := os.environ.get("NANOCLAW_DIR"):
        return Path(env).expanduser()
    here = Path(__file__).resolve()
    for parent in (here.parent, here.parent.parent, here.parent.parent.parent):
        if (parent / "data" / "cli.sock").exists() or (parent / "data" / "v2.db").exists():
            return parent
        if (parent / ".env").exists() and (parent / "data").is_dir():
            return parent
    return Path.home() / "src" / "nanoclaw"


NANOCLAW_DIR = _find_nanoclaw_dir()
DATA_DIR = NANOCLAW_DIR / "data"
SOCKET_PATH = DATA_DIR / "cli.sock"
DB_PATH = DATA_DIR / "v2.db"


# ── Group listing ──────────────────────────────────────────────────────────

def list_groups() -> int:
    """Show messaging groups and which agent group is wired to each."""
    if not DB_PATH.exists():
        print(f"No NanoClaw v2 database found at {DB_PATH}.", file=sys.stderr)
        return 1
    conn = sqlite3.connect(f"file:{DB_PATH}?mode=ro", uri=True)
    rows = conn.execute(
        """
        SELECT
            mg.channel_type,
            mg.platform_id,
            mg.name,
            ag.name AS agent_name,
            ag.folder
        FROM messaging_groups mg
        LEFT JOIN messaging_group_agents mga
            ON mga.messaging_group_id = mg.id
        LEFT JOIN agent_groups ag
            ON ag.id = mga.agent_group_id
        ORDER BY mg.channel_type, mg.name
        """
    ).fetchall()
    conn.close()
    if not rows:
        print("No messaging groups wired yet.", file=sys.stderr)
        return 0
    print(f"{'CHANNEL':<10} {'PLATFORM ID':<32} {'NAME':<24} {'AGENT':<20} FOLDER")
    print("-" * 100)
    for channel_type, platform_id, name, agent_name, folder in rows:
        print(
            f"{channel_type or '-':<10} "
            f"{(platform_id or '-')[:32]:<32} "
            f"{(name or '-')[:24]:<24} "
            f"{(agent_name or '-')[:20]:<20} "
            f"{folder or '-'}"
        )
    return 0


# ── Send + receive ──────────────────────────────────────────────────────────

def send_prompt(prompt: str, timeout: int) -> int:
    """Open `data/cli.sock`, send the prompt, stream replies to stdout."""
    if not SOCKET_PATH.exists():
        print(
            f"NanoClaw CLI socket not found at {SOCKET_PATH}.\n"
            "Start the NanoClaw service before running claw "
            "(launchctl/systemd — see docs/DEBUG_CHECKLIST.md).",
            file=sys.stderr,
        )
        return 2

    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        s.connect(str(SOCKET_PATH))
    except (FileNotFoundError, ConnectionRefusedError, PermissionError) as e:
        print(f"NanoClaw daemon not reachable at {SOCKET_PATH}: {e}", file=sys.stderr)
        return 2

    payload = json.dumps({"text": prompt}) + "\n"
    try:
        s.sendall(payload.encode("utf-8"))
    except OSError as e:
        print(f"Failed to send prompt: {e}", file=sys.stderr)
        s.close()
        return 2
    dbg(f"sent: {payload.strip()}")

    s.settimeout(timeout)
    first_reply_seen = False
    buffer = b""
    deadline: float | None = None
    exit_code = 3

    try:
        while True:
            try:
                if deadline is not None:
                    remaining = deadline - time.monotonic()
                    if remaining <= 0:
                        break
                    s.settimeout(remaining)
                chunk = s.recv(4096)
            except socket.timeout:
                if first_reply_seen:
                    break
                print(f"timeout: no reply in {timeout}s", file=sys.stderr)
                return 3
            if not chunk:
                # Server closed the connection.
                break
            buffer += chunk
            while b"\n" in buffer:
                line, buffer = buffer.split(b"\n", 1)
                text_line = line.decode("utf-8", errors="replace").strip()
                if not text_line:
                    continue
                try:
                    msg = json.loads(text_line)
                except json.JSONDecodeError:
                    dbg(f"non-JSON line ignored: {text_line}")
                    continue
                text = msg.get("text") if isinstance(msg, dict) else None
                if isinstance(text, str):
                    print(text)
                    first_reply_seen = True
                    deadline = time.monotonic() + SILENCE_SECS
                    exit_code = 0
    finally:
        try:
            s.close()
        except OSError:
            pass

    return exit_code


# ── Main ────────────────────────────────────────────────────────────────────

DEPRECATED_FLAGS = ("group", "jid", "session", "runtime", "image")


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="claw",
        description="Send a prompt to your NanoClaw agent via the local CLI socket.",
    )
    parser.add_argument("prompt", nargs="?", help="Prompt to send")
    parser.add_argument(
        "-p", "--pipe", action="store_true",
        help="Read prompt from stdin (can be combined with a prompt arg as prefix)",
    )
    parser.add_argument(
        "--list-groups", action="store_true",
        help="List wired messaging groups and exit",
    )
    parser.add_argument(
        "--timeout", type=int, default=DEFAULT_TIMEOUT, metavar="SECS",
        help=f"Max seconds to wait for the first reply (default: {DEFAULT_TIMEOUT})",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true",
        help="Show debug info (resolved paths, sent JSON)",
    )

    # Deprecated v1 flags — kept hidden so users get a clear message instead of
    # a generic argparse error if they invoke the old UX.
    parser.add_argument("-g", "--group", help=argparse.SUPPRESS)
    parser.add_argument("-j", "--jid", help=argparse.SUPPRESS)
    parser.add_argument("-s", "--session", help=argparse.SUPPRESS)
    parser.add_argument("--runtime", help=argparse.SUPPRESS)
    parser.add_argument("--image", help=argparse.SUPPRESS)
    parser.add_argument("--raw", action="store_true", help=argparse.SUPPRESS)

    args = parser.parse_args()

    global VERBOSE
    VERBOSE = args.verbose
    dbg(f"NANOCLAW_DIR: {NANOCLAW_DIR}")
    dbg(f"SOCKET_PATH:  {SOCKET_PATH}")
    dbg(f"DB_PATH:      {DB_PATH}")

    used_deprecated = [name for name in DEPRECATED_FLAGS if getattr(args, name)]
    if used_deprecated:
        flags = ", ".join("--" + n for n in used_deprecated)
        print(
            f"claw v2: {flags} no longer supported.\n"
            "Chat now flows through `data/cli.sock` to whichever agent is wired\n"
            "to cli/local. To talk to a specific channel's agent, either use that\n"
            "channel's chat app, or wire it to cli/local (see /init-cli-agent or\n"
            "/manage-channels).",
            file=sys.stderr,
        )
        return 2

    if args.list_groups:
        return list_groups()

    if args.pipe or (not sys.stdin.isatty() and not args.prompt):
        stdin_text = sys.stdin.read().strip()
        if args.prompt:
            prompt = f"{args.prompt}\n\n{stdin_text}"
        else:
            prompt = stdin_text
    else:
        prompt = args.prompt

    if not prompt:
        parser.print_help()
        return 1

    return send_prompt(prompt, args.timeout)


if __name__ == "__main__":
    sys.exit(main())
