TELEGRAM_BOT_TOKEN=

# Claude authentication (one of these is required)
# CLAUDE_CODE_OAUTH_TOKEN=              # Claude account subscription token (run: claude setup-token)
# ANTHROPIC_API_KEY=                    # Anthropic API key

# Assistant identity
# ASSISTANT_NAME=Andy                   # Name shown in messages and used for trigger detection
# TRIGGER_PATTERN=@Andy                 # Regex pattern to trigger the assistant in group chats
# TIMEZONE=America/New_York             # Timezone for scheduled tasks

# Signal (requires signal-cli — see docs/signal-setup.md)
# SIGNAL_ACCOUNT=+1YOURNUMBER          # Registered phone number
# SIGNAL_CLI_PATH=signal-cli            # Path to signal-cli binary (default: signal-cli)
# SIGNAL_HTTP_HOST=127.0.0.1            # Daemon HTTP listen address (default: 127.0.0.1)
# SIGNAL_HTTP_PORT=7583                 # Daemon HTTP listen port (default: 7583)
# SIGNAL_MANAGE_DAEMON=true             # Let NanoClaw start/stop the daemon (default: true)
# ASSISTANT_HAS_OWN_NUMBER=true         # Set if assistant has its own phone number (not sharing via Note to Self)
